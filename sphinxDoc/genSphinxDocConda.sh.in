#!/usr/bin/env bash

isPypiBuild=@IS_PYPI_BUILD@

if [ $isPypiBuild = "true" ] ; then
    #. ${CONDA_ROOT}/etc/profile.d/conda.sh                                             # required to have access to conda commands in a shell script
    #conda activate ${CONDA_ENV}
    #export LD_LIBRARY_PATH=.:${CMAKE_PREFIX_PATH}/lib:${LD_LIBRARY_PATH}
    rm @SPHINXDOCTREES@/*.doctree
    @SPHINXBUILD@ -c @CMAKE_BINARY_DIR@/sphinxDoc -b html -d @SPHINXDOCTREES@ @ALLSPHINXOPTS@ @CMAKE_INSTALL_PREFIX@/cloudComPy/doc/html 
    python @CMAKE_BINARY_DIR@/sphinxDoc/getDependency.py "@CMAKE_INSTALL_PREFIX@/cloudComPy" ${QT_PREFIX}
else
    . @CMAKE_INSTALL_PREFIX@/bin/condaCloud.sh activate ${CONDA_DEFAULT_ENV}
    rm @SPHINXDOCTREES@/*.doctree
    @SPHINXBUILD@ -c @CMAKE_BINARY_DIR@/sphinxDoc -b html -d @SPHINXDOCTREES@ @ALLSPHINXOPTS@ @CMAKE_INSTALL_PREFIX@/doc/html 
fi
