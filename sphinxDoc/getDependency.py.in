#!/usr/bin/env python3

import argparse
import os
import subprocess
import sys
import shutil

def getDepLibs(packagePath="@CMAKE_INSTALL_PREFIX@/cloudComPy", QtPrefix="--- IGNORE ---"):
    """
    Linux only!
    Find all the libraries (*.so*) used by cloudComPy, CloudCompare, ccViewer, to be added to the bundle.
    The system libraries (in /usr and /lib) are not taken into account.
    Also fix the RPATH of each library to look in the same directory (with $ORIGIN).
    The steps are:
    0) check that QtPrefix is valid and copy the Qt plugins
    1) look for all the executables and libraries in the package
    2) for each of them, use ldd to find the dependencies
    3) copy the dependencies in the package directory
    4) fix the RPATH of each library to look in the same directory (with $ORIGIN)
    5) also look for Qt plugins dependencies in the Qt plugins directory
    6) copy the Qt plugins dependencies in the package directory
    7) fix the RPATH of each Qt plugin to look in the same directory (with $ORIGIN)
    8) done
    """
    print("+++++++++++++++++++++++++++++++++++++++++++++++++++++")
    print(os.environ)
    print("+++++++++++++++++++++++++++++++++++++++++++++++++++++")
    
    # --- copy the Qt plugins path
    qtPluginsPath = os.path.join(QtPrefix, "plugins")
    print("Qt plugins path: ", qtPluginsPath)
    if not os.path.exists(qtPluginsPath):
        print(" ************************ Error: Qt plugins path does not exist: ", qtPluginsPath)
        sys.exit(1) 
    shutil.copytree(qtPluginsPath, os.path.join(packagePath, "plugins"), dirs_exist_ok=True)
    # --- list the Qt plugins libraries
    libsQtPlugins = []
    for root, dirs, files in os.walk(os.path.join(packagePath, "plugins")): 
        for f in files:
            pf = os.path.join(root,f)
            ext = os.path.splitext(pf)[1]
            if ext == ('.so'):
                libsQtPlugins.append(pf)  

    # --- CloudCompare and ccViewer executables are always analysed
    pathlibs = [os.path.join(packagePath, "CloudCompare"), os.path.join(packagePath, "ccViewer")]

    # --- get all the *.so from the package, to look for dependencies
    for root, dirs, files in os.walk(packagePath):
        for f in files:
            pf = os.path.join(root,f)
            ext = os.path.splitext(pf)[1]
            if ext == ('.so'):
                pathlibs.append(pf)

    # --- the dependency libraries will be added a set to avoid duplicates
    libs = set()

    # --- for each library or executable in the package, find all dependencies
    for pathLibmain in pathlibs:
        libs.add(str(pathLibmain))
        with subprocess.Popen(["ldd", str(pathLibmain)], stdout=subprocess.PIPE) as proc:
            lines = proc.stdout.readlines()
            for line in lines:
                res = line.decode()
                vals = res.split()
                if len(vals) > 3:
                    f = vals[2]
                    if f == 'not' and vals[3] == 'found':
                        print("Warning: library not found for ", vals[0])
                        print("for executable/library: ", pathLibmain)
                    elif not (f.startswith('/lib') or f.startswith('/usr')):
                        libs.add(f)

    # --- copy the dependencies and fix RPATH (look in the same directory)
    for orig in libs:
        dest = os.path.join(packagePath, os.path.basename(orig))
        print(dest)
        if orig != dest:
            if not os.path.isfile(orig):
                print(" ************** Warning: dependency library does not exist: ", orig)
                continue
            shutil.copy(orig, dest)
        subprocess.Popen(["patchelf", "--set-rpath", r"$ORIGIN", str(dest)])

    # --- fix rpath of Qt plugins
    for libQt in libsQtPlugins:
        subprocess.Popen(["patchelf", "--set-rpath", r"$ORIGIN/../..:$ORIGIN", str(libQt)])

if __name__ == "__main__":
    # CLI parser
    parser = argparse.ArgumentParser("cloudComPyBundle")
    parser.add_argument(
        "install_path",
        help="Path where cloudComPy is installed (CMake install dir)"
    )
    parser.add_argument(
        "QT_PREFIX",
        help="Qt prefix Path where Qt plugins are located (where is plugins directory)"
    )
    arguments = parser.parse_args()
    getDepLibs(arguments.install_path, arguments.QT_PREFIX) 
    