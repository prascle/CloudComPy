#!/usr/bin/env bash

isPypiBuild=@IS_PYPI_BUILD@

if [ $isPypiBuild = "true" ] ; then
    export LD_LIBRARY_PATH=.:${QT_PREFIX}/lib:@CMAKE_INSTALL_PREFIX@/cloudComPy:@CMAKE_INSTALL_PREFIX@/cloudComPy/plugins/CC:${LD_LIBRARY_PATH}
    export PYTHONPATH=@CMAKE_INSTALL_PREFIX@:${PYTHONPATH}
else
    export LD_LIBRARY_PATH=@CMAKE_INSTALL_PREFIX@/lib/cloudcompare/plugins:@CMAKE_INSTALL_PREFIX@/lib/cloudcompare:${LD_LIBRARY_PATH}
fi

echo ${LD_LIBRARY_PATH}
ldd @CMAKE_INSTALL_PREFIX@/cloudComPy/_cloudComPy.cpython-39-x86_64-linux-gnu.so

rm @SPHINXDOCTREES@/*.doctree

if [ $isPypiBuild = "true" ] ; then
    @SPHINXBUILD@ -c @CMAKE_BINARY_DIR@/sphinxDoc -b html -d @SPHINXDOCTREES@ @ALLSPHINXOPTS@ @CMAKE_INSTALL_PREFIX@/cloudComPy/doc/html 
else
    @SPHINXBUILD@ -c @CMAKE_BINARY_DIR@/sphinxDoc -b html -d @SPHINXDOCTREES@ @ALLSPHINXOPTS@ @CMAKE_INSTALL_PREFIX@/doc/html 
fi

python @CMAKE_BINARY_DIR@/sphinxDoc/getDependency.py "@CMAKE_INSTALL_PREFIX@/cloudComPy" ${QT_PREFIX}
